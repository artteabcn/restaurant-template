# Meta WhatsApp Cloud API (free tier: 1000 conversations/month)
# Get these at https://developers.facebook.com/ → WhatsApp Business → API Setup
META_WA_TOKEN=
META_WA_PHONE_ID=

# Behold.so Instagram feed
# Create a free feed at https://behold.so for your Instagram account and paste the feed ID
PUBLIC_BEHOLD_FEED_ID=

# Override the WHATSAPP_TO from wrangler.toml during local dev (optional)
WHATSAPP_TO=
