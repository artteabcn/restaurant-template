---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Ornament from "@/components/Ornament.astro";
import { useTranslations, getDictionary, localizedPath, type Locale, locales } from "@/i18n/utils";
import { siteConfig } from "@/config/site";
import type { MenuItem } from "@/config/types";

export const prerender = true;

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const romanNumerals = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"];
const pages = siteConfig.images.menu.map((src, i) => ({
  src,
  numeral: romanNumerals[i] ?? String(i + 1),
}));

const menuMode = siteConfig.menuMode ?? (pages.length > 0 ? "photos" : "items");
const showPhotos = menuMode === "photos" || menuMode === "both";
const showItems = menuMode === "items" || menuMode === "both";

// Read menu items from i18n JSON — use getDictionary() since t() only returns strings
const dict = getDictionary(locale);
const menuItems: MenuItem[] = Array.isArray(dict.menuItems) ? (dict.menuItems as unknown as MenuItem[]) : [];

// Group items by category
const categories = [...new Set(menuItems.map(it => it.category || ""))];
function itemsInCategory(cat: string) {
  return menuItems.filter(it => (it.category || "") === cat);
}

const TAG_LABELS: Record<string, string> = {
  veg: "V",
  vegan: "VG",
  gf: "GF",
  spicy: "🌶",
};
---

<BaseLayout title={t("menu.title")}>
  <!-- Header -->
  <section class="container-narrow pt-24 pb-12 text-center max-w-2xl">
    <p class="eyebrow mb-6">{t("hero.eyebrow")}</p>
    <h1 class="display italic text-5xl md:text-7xl text-[var(--color-gold-soft)] mb-8">
      {t("menu.title")}
    </h1>
    <Ornament class="mb-10" />
    <p class="text-lg text-[var(--color-fg-muted)] leading-loose font-light">
      {t("menu.intro")}
    </p>
  </section>

  <!-- Written menu -->
  {showItems && menuItems.length > 0 && (
    <section class="container-narrow pb-16" aria-label={t("menu.title")}>
      <div class="max-w-2xl mx-auto">
        {categories.map((cat) => (
          <div class="mb-12">
            {cat && (
              <div class="flex items-center gap-4 mb-6">
                <span class="block h-px flex-1 bg-[var(--color-line)]" />
                <p class="eyebrow text-[var(--color-gold)]">{cat}</p>
                <span class="block h-px flex-1 bg-[var(--color-line)]" />
              </div>
            )}
            <ul class="divide-y divide-[var(--color-line)]">
              {itemsInCategory(cat).map((item) => (
                <li class="py-5 flex gap-4 items-baseline justify-between">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-2 flex-wrap">
                      <span class="font-display italic text-xl text-[var(--color-fg)]">{item.name}</span>
                      {item.tags.map(tag => (
                        <span class="text-[0.6rem] font-medium tracking-wider uppercase px-1.5 py-0.5 rounded border border-[var(--color-line)] text-[var(--color-fg-subtle)]">
                          {TAG_LABELS[tag] ?? tag}
                        </span>
                      ))}
                    </div>
                    {item.description && (
                      <p class="text-sm text-[var(--color-fg-muted)] font-light mt-1 leading-relaxed">
                        {item.description}
                      </p>
                    )}
                  </div>
                  {item.price && (
                    <span class="text-[var(--color-gold-deep)] font-medium text-base shrink-0 ml-4">
                      {item.price}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Photo menu -->
  {showPhotos && pages.length > 0 && (
    <section class="container-narrow pb-24" aria-label={t("menu.title")}>
      <div class="grid md:grid-cols-2 gap-10 md:gap-14" id="menu-grid">
        {pages.map((p, i) => (
          <figure class="menu-card group">
            <div class="menu-numeral">
              <span class="block h-px w-10 bg-gradient-to-r from-transparent to-[var(--color-gold-deep)] opacity-70" />
              <span class="display italic text-base text-[var(--color-gold)]">{p.numeral}</span>
              <span class="block h-px w-10 bg-gradient-to-l from-transparent to-[var(--color-gold-deep)] opacity-70" />
            </div>
            <button type="button" data-menu-open={i} class="menu-frame block w-full cursor-zoom-in" aria-label={`${t("menu.title")} · ${p.numeral}`}>
              <img src={p.src} alt={`${t("menu.title")} · ${p.numeral}`} loading="lazy" decoding="async" class="block w-full h-auto" />
            </button>
          </figure>
        ))}
      </div>
    </section>
  )}

  <!-- No content fallback -->
  {!showPhotos && (!showItems || menuItems.length === 0) && (
    <section class="container-narrow pb-24 text-center max-w-2xl">
      <p class="text-lg text-[var(--color-fg-muted)] italic mb-4">{t("menu.comingSoon")}</p>
      <p class="text-sm text-[var(--color-fg-subtle)]">{t("menu.comingSoonSub")}</p>
    </section>
  )}

  <!-- Closing reserve CTA -->
  <section class="container-narrow pb-32 text-center max-w-2xl">
    <Ornament class="mb-8" />
    <p class="display italic text-3xl md:text-4xl text-[var(--color-gold-soft)] mb-8 leading-snug">
      {t("menu.cta")}
    </p>
    <a href={localizedPath(locale, "/booking")} class="btn-primary">
      {t("reservation.cta")}
    </a>
  </section>

  <!-- Lightbox (only when photos present) -->
  {pages.length > 0 && (
    <dialog id="menu-lightbox" class="lightbox" aria-label={t("menu.title")} data-pages={JSON.stringify(pages)}>
      <div class="lightbox-inner">
        <button type="button" class="lightbox-close" data-menu-close aria-label="Close">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M5 5 L19 19 M19 5 L5 19" /></svg>
        </button>
        <button type="button" class="lightbox-arrow lightbox-prev" data-menu-prev aria-label="Previous">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M15 5 L8 12 L15 19" /></svg>
        </button>
        <button type="button" class="lightbox-arrow lightbox-next" data-menu-next aria-label="Next">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M9 5 L16 12 L9 19" /></svg>
        </button>
        <figure class="lightbox-figure">
          <div class="lightbox-frame">
            <img id="lightbox-img" src="" alt="" />
          </div>
          <figcaption class="lightbox-caption">
            <span class="block h-px w-10 bg-gradient-to-r from-transparent to-[var(--color-gold-deep)] opacity-70" />
            <span class="display italic text-base text-[var(--color-gold)]" id="lightbox-numeral">I</span>
            <span class="opacity-50">·</span>
            <span class="text-[0.7rem] uppercase tracking-[0.28em] text-[var(--color-fg-muted)]">
              <span id="lightbox-index">1</span> / <span>{pages.length}</span>
            </span>
            <span class="block h-px w-10 bg-gradient-to-l from-transparent to-[var(--color-gold-deep)] opacity-70" />
          </figcaption>
        </figure>
      </div>
    </dialog>
  )}
</BaseLayout>

<script is:inline>
  (() => {
    const dialog = document.getElementById("menu-lightbox");
    if (!dialog) return;
    const img = document.getElementById("lightbox-img");
    const numeralEl = document.getElementById("lightbox-numeral");
    const indexEl = document.getElementById("lightbox-index");
    const pages = JSON.parse(dialog.dataset.pages || "[]");
    let current = 0;
    const render = () => { const p = pages[current]; if (!p || !img) return; img.src = p.src; img.alt = ""; if (numeralEl) numeralEl.textContent = p.numeral; if (indexEl) indexEl.textContent = String(current + 1); };
    const open = (i) => { current = ((i % pages.length) + pages.length) % pages.length; render(); if (typeof dialog.showModal === "function") dialog.showModal(); else dialog.setAttribute("open", ""); document.body.style.overflow = "hidden"; };
    const close = () => { if (typeof dialog.close === "function") dialog.close(); else dialog.removeAttribute("open"); document.body.style.overflow = ""; };
    const next = () => { current = (current + 1) % pages.length; render(); };
    const prev = () => { current = (current - 1 + pages.length) % pages.length; render(); };
    document.querySelectorAll("[data-menu-open]").forEach(btn => btn.addEventListener("click", e => { e.preventDefault(); open(Number(btn.getAttribute("data-menu-open"))); }));
    dialog.querySelector("[data-menu-close]")?.addEventListener("click", close);
    dialog.querySelector("[data-menu-next]")?.addEventListener("click", next);
    dialog.querySelector("[data-menu-prev]")?.addEventListener("click", prev);
    dialog.addEventListener("click", e => { if (e.target === dialog) close(); });
    document.addEventListener("keydown", e => { if (!dialog.open) return; if (e.key === "ArrowRight") { e.preventDefault(); next(); } else if (e.key === "ArrowLeft") { e.preventDefault(); prev(); } });
    dialog.addEventListener("close", () => { document.body.style.overflow = ""; });
    let touchStartX = 0;
    dialog.addEventListener("touchstart", e => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    dialog.addEventListener("touchend", e => { const dx = e.changedTouches[0].screenX - touchStartX; if (Math.abs(dx) > 50) { if (dx < 0) next(); else prev(); } }, { passive: true });
  })();
</script>

<style>
  .menu-card { display: flex; flex-direction: column; align-items: center; gap: 1.25rem; margin: 0; }
  .menu-numeral { display: flex; align-items: center; gap: 0.85rem; letter-spacing: 0.18em; }
  .menu-frame { position: relative; border: 1px solid var(--color-line); border-radius: var(--radius-sm); padding: 0.6rem; background: linear-gradient(180deg, oklch(from var(--color-surface) l c h / 0.6), oklch(from var(--color-bg-2) l c h / 0.6)); box-shadow: 0 1px 0 0 oklch(from var(--color-gold) l c h / 0.15), 0 24px 60px -30px oklch(0 0 0 / 0.55); transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease, border-color 0.3s ease; overflow: hidden; }
  .menu-frame img { border-radius: 1px; }
  .menu-card:hover .menu-frame { transform: translateY(-4px); border-color: var(--color-gold-deep); box-shadow: 0 1px 0 0 oklch(from var(--color-gold) l c h / 0.3), 0 36px 80px -30px oklch(0 0 0 / 0.7), 0 0 60px -20px oklch(from var(--color-accent) l c h / 0.4); }
  .lightbox { width: 100vw; max-width: 100vw; height: 100dvh; max-height: 100dvh; margin: 0; padding: 0; border: 0; background: transparent; color: var(--color-fg); overflow: hidden; }
  .lightbox::backdrop { background: radial-gradient(ellipse at center, oklch(0.13 0.04 25 / 0.96), oklch(0.06 0.02 22 / 0.98)); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
  .lightbox[open] .lightbox-inner { animation: lightbox-fade 0.35s cubic-bezier(0.22, 1, 0.36, 1); }
  .lightbox-inner { position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 2.5rem 3.5rem; }
  .lightbox-figure { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 1rem; max-height: 100%; }
  .lightbox-frame { border: 1px solid var(--color-gold-deep); border-radius: var(--radius-sm); padding: 0.5rem; background: linear-gradient(180deg, oklch(from var(--color-surface) l c h / 0.85), oklch(from var(--color-bg-2) l c h / 0.85)); box-shadow: 0 1px 0 0 oklch(from var(--color-gold) l c h / 0.3), 0 40px 100px -30px oklch(0 0 0 / 0.8), 0 0 80px -20px oklch(from var(--color-accent) l c h / 0.35); max-width: min(92vw, 720px); max-height: calc(100dvh - 9rem); overflow: hidden; }
  .lightbox-frame img { display: block; width: 100%; height: auto; max-height: calc(100dvh - 11rem); object-fit: contain; border-radius: 1px; }
  .lightbox-caption { display: flex; align-items: center; gap: 0.85rem; padding-top: 0.25rem; }
  .lightbox-close { position: absolute; top: 1.2rem; right: 1.2rem; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; background: oklch(from var(--color-bg) l c h / 0.6); border: 1px solid var(--color-line-strong); border-radius: 9999px; color: var(--color-fg-muted); cursor: pointer; transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease; }
  .lightbox-close:hover { color: var(--color-gold-soft); border-color: var(--color-gold); background: oklch(from var(--color-bg-2) l c h / 0.85); }
  .lightbox-arrow { position: absolute; top: 50%; transform: translateY(-50%); width: 3rem; height: 3rem; display: flex; align-items: center; justify-content: center; background: oklch(from var(--color-bg) l c h / 0.55); border: 1px solid var(--color-line-strong); border-radius: 9999px; color: var(--color-fg-muted); cursor: pointer; transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease; }
  .lightbox-arrow:hover { color: var(--color-gold-soft); border-color: var(--color-gold); background: oklch(from var(--color-bg-2) l c h / 0.85); }
  .lightbox-prev { left: 1rem; }
  .lightbox-next { right: 1rem; }
  @media (max-width: 640px) { .lightbox-inner { padding: 2rem 0.75rem; } .lightbox-arrow { width: 2.5rem; height: 2.5rem; } .lightbox-prev { left: 0.5rem; } .lightbox-next { right: 0.5rem; } }
  @keyframes lightbox-fade { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); } }
  @media (prefers-reduced-motion: reduce) { .menu-frame { transition: none; } .menu-card:hover .menu-frame { transform: none; } .lightbox[open] .lightbox-inner { animation: none; } }
</style>