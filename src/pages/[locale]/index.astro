---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/HeroSection.astro";
import OpeningHours from "@/components/OpeningHours.astro";
import ContactSection from "@/components/ContactSection.astro";
import InstagramFeed from "@/components/InstagramFeed.astro";
import ReservationStrip from "@/components/ReservationStrip.astro";
import Ornament from "@/components/Ornament.astro";
import { useTranslations, type Locale, locales } from "@/i18n/utils";
import { siteConfig } from "@/config/site";

export const prerender = true;

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
---

<BaseLayout title={`${siteConfig.name} · ${t("hero.eyebrow")}`}>
  <HeroSection locale={locale} />

  <!-- About — asymmetric pullquote split -->
  <section id="about" class="container-narrow py-24 md:py-32">
    <div class="grid md:grid-cols-12 gap-10 md:gap-16 items-start">
      <div class="md:col-span-5 md:sticky md:top-32">
        <p class="eyebrow mb-5">{t("about.title")}</p>
        <p
          class="display italic text-3xl md:text-5xl text-[var(--color-gold-soft)] leading-[1.05]"
        >
          "{t("about.pullquote")}"
        </p>
        <div
          class="mt-8 flex items-center gap-3 text-[var(--color-gold)]"
          aria-hidden="true"
        >
          <span
            class="block h-px w-16 bg-gradient-to-r from-[var(--color-gold-deep)] via-[var(--color-gold)] to-transparent opacity-70"
          ></span>
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="0.7"
          >
            <path
              d="M12 3 L13.5 10.5 L21 12 L13.5 13.5 L12 21 L10.5 13.5 L3 12 L10.5 10.5 Z"
              opacity="0.85"></path>
            <circle cx="12" cy="12" r="1" fill="currentColor"></circle>
          </svg>
        </div>
      </div>
      <div
        class="md:col-span-6 md:col-start-7 md:border-l md:border-[var(--color-line)] md:pl-10"
      >
        <p class="text-lg md:text-xl text-[var(--color-fg-muted)] leading-loose font-light">
          {t("about.body")}
        </p>
      </div>
    </div>
  </section>

  <!-- Menu photo grid -->
  {
    siteConfig.images.menu.length > 0 && (
      <section class="container-narrow py-8">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
          {siteConfig.images.menu.map((src, i) => (
            <div class="aspect-square overflow-hidden">
              <img
                src={src}
                alt={`${t("menu.title")} ${i + 1}`}
                loading="lazy"
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              />
            </div>
          ))}
        </div>
      </section>
    )
  }

  <ReservationStrip locale={locale} />

  <div id="hours">
    <OpeningHours locale={locale} />
  </div>

  <InstagramFeed locale={locale} />
  <ContactSection locale={locale} />
</BaseLayout>
