---
import { useTranslations, localizedPath, type Locale } from "@/i18n/utils";
import Ornament from "./Ornament.astro";
import { siteConfig } from "@/config/site";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const fmt = new Intl.DateTimeFormat("en-US", {
  weekday: "long",
  timeZone: siteConfig.timezone,
});
const todayName = fmt.format(new Date()).toLowerCase() as keyof typeof siteConfig.hours;
const isClosedToday = siteConfig.hours[todayName] === null;
---

<section
  class="relative overflow-hidden min-h-[92vh] flex items-center"
  aria-label={siteConfig.name}
>
  <!-- candlelight layers -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(circle at 18% 28%, oklch(0.55 0.16 35 / 0.32), transparent 38%),
        radial-gradient(circle at 82% 22%, oklch(0.5 0.13 28 / 0.22), transparent 42%),
        radial-gradient(circle at 60% 78%, oklch(0.6 0.12 60 / 0.16), transparent 50%),
        radial-gradient(circle at 22% 80%, oklch(0.45 0.15 22 / 0.28), transparent 45%);"
    >
    </div>
    <!-- soft animated flicker -->
    <div class="absolute inset-0 hero-flicker"></div>
    <!-- film-grain feel -->
    <div
      class="absolute inset-0 opacity-[0.05] mix-blend-overlay"
      style="background-image:
        repeating-linear-gradient(0deg, #fff 0 1px, transparent 1px 3px),
        repeating-linear-gradient(90deg, #fff 0 1px, transparent 1px 3px);"
    >
    </div>
  </div>

  <!-- baroque arch glyph behind wordmark -->
  <svg
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-[58%] w-[min(92vw,820px)] h-auto opacity-[0.08] pointer-events-none"
    viewBox="0 0 800 600"
    fill="none"
    stroke="currentColor"
    stroke-width="0.7"
    aria-hidden="true"
    style="color: var(--color-gold);"
  >
    <path d="M120 540 L120 280 Q120 100 400 100 Q680 100 680 280 L680 540" />
    <path d="M150 540 L150 290 Q150 130 400 130 Q650 130 650 290 L650 540" />
    <path d="M400 130 L400 540" stroke-dasharray="2 8" />
    <circle cx="400" cy="130" r="3" fill="currentColor" />
    <path d="M180 540 L620 540" />
    <path d="M180 555 L620 555" />
  </svg>

  <!-- corner ornaments -->
  <div
    class="absolute top-6 left-6 opacity-50 text-[var(--color-gold-deep)]"
    aria-hidden="true"
  >
    <svg
      width="34"
      height="34"
      viewBox="0 0 40 40"
      fill="none"
      stroke="currentColor"
      stroke-width="0.7"
    >
      <path d="M2 2 L2 14 M2 2 L14 2" />
      <path d="M2 2 Q10 2 14 14" opacity="0.5" />
      <circle cx="2" cy="2" r="1" fill="currentColor" />
    </svg>
  </div>
  <div
    class="absolute top-6 right-6 opacity-50 text-[var(--color-gold-deep)] -scale-x-100"
    aria-hidden="true"
  >
    <svg
      width="34"
      height="34"
      viewBox="0 0 40 40"
      fill="none"
      stroke="currentColor"
      stroke-width="0.7"
    >
      <path d="M2 2 L2 14 M2 2 L14 2" />
      <path d="M2 2 Q10 2 14 14" opacity="0.5" />
      <circle cx="2" cy="2" r="1" fill="currentColor" />
    </svg>
  </div>
  <div
    class="absolute bottom-6 left-6 opacity-50 text-[var(--color-gold-deep)] -scale-y-100"
    aria-hidden="true"
  >
    <svg
      width="34"
      height="34"
      viewBox="0 0 40 40"
      fill="none"
      stroke="currentColor"
      stroke-width="0.7"
    >
      <path d="M2 2 L2 14 M2 2 L14 2" />
      <path d="M2 2 Q10 2 14 14" opacity="0.5" />
      <circle cx="2" cy="2" r="1" fill="currentColor" />
    </svg>
  </div>
  <div
    class="absolute bottom-6 right-6 opacity-50 text-[var(--color-gold-deep)] -scale-100"
    aria-hidden="true"
  >
    <svg
      width="34"
      height="34"
      viewBox="0 0 40 40"
      fill="none"
      stroke="currentColor"
      stroke-width="0.7"
    >
      <path d="M2 2 L2 14 M2 2 L14 2" />
      <path d="M2 2 Q10 2 14 14" opacity="0.5" />
      <circle cx="2" cy="2" r="1" fill="currentColor" />
    </svg>
  </div>

  <div
    class="container-narrow relative pt-12 pb-20 md:pt-16 md:pb-28 text-center w-full"
  >
    <!-- live status pill -->
    <div class="flex justify-center mb-10 hero-fade" style="--d:0ms;">
      <span
        class:list={[
          "inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border text-[0.66rem] uppercase tracking-[0.28em] backdrop-blur-sm",
          isClosedToday
            ? "border-white/20 text-white/70 bg-[oklch(0.13_0.018_25/0.55)]"
            : "border-[var(--color-gold-deep)] text-[var(--color-gold-soft)] bg-[oklch(0.18_0.04_25/0.5)]",
        ]}
      >
        <span
          class:list={[
            "h-1.5 w-1.5 rounded-full",
            isClosedToday
              ? "bg-white/50"
              : "bg-[var(--color-gold)] hero-pulse",
          ]}
          aria-hidden="true"></span>
        {isClosedToday ? t("hours.closedLabel") : t("hours.openNow")}
        <span class="opacity-60">·</span>
        <span class="opacity-80 normal-case tracking-[0.22em]">
          {isClosedToday ? t("hours.closedSubline") : t("hours.openSubline")}
        </span>
      </span>
    </div>

    <p class="eyebrow mb-8 hero-fade" style="--d:120ms;">{t("hero.eyebrow")}</p>

    <h1
      class="display italic text-[var(--color-gold-soft)] leading-[0.9] hero-fade"
      style="--d:200ms; font-size:clamp(4.5rem, 14vw, 11rem);"
    >
      {t("hero.title")}
    </h1>

    <div class="hero-fade" style="--d:340ms;">
      <Ornament class="my-10" />
    </div>

    <p
      class="mx-auto max-w-xl text-lg md:text-xl text-[var(--color-fg-muted)] leading-relaxed font-light hero-fade"
      style="--d:440ms;"
    >
      {t("hero.subtitle")}
    </p>

    <div class="mt-12 flex flex-wrap justify-center gap-4 hero-fade" style="--d:560ms;">
      <a href={localizedPath(locale, "/booking")} class="btn-primary">
        {t("hero.cta")}
      </a>
      <a href="#hours" class="btn-ghost">
        {t("hero.secondaryCta")}
      </a>
    </div>
  </div>

  <!-- scroll cue -->
  <a
    href="#about"
    class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[0.6rem] uppercase tracking-[0.32em] text-[var(--color-fg-subtle)] hover:text-[var(--color-gold)] transition-colors flex flex-col items-center gap-2"
    aria-label="Scroll"
  >
    <span>{t("hero.tonight")}</span>
    <span class="h-8 w-px bg-gradient-to-b from-[var(--color-gold-deep)] to-transparent"
    ></span>
  </a>
</section>

<style>
  @keyframes hero-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero-fade {
    opacity: 0;
    animation: hero-fade-in 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0ms);
  }

  @keyframes hero-flicker {
    0%,
    100% {
      opacity: 1;
    }
    20% {
      opacity: 0.96;
    }
    50% {
      opacity: 1.02;
    }
    80% {
      opacity: 0.97;
    }
  }
  .hero-flicker {
    background:
      radial-gradient(
        circle at 30% 40%,
        oklch(0.7 0.15 60 / 0.05),
        transparent 25%
      ),
      radial-gradient(
        circle at 70% 60%,
        oklch(0.7 0.15 40 / 0.04),
        transparent 30%
      );
    animation: hero-flicker 6s ease-in-out infinite;
  }

  @keyframes hero-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 oklch(0.79 0.115 80 / 0.5);
    }
    50% {
      box-shadow: 0 0 0 4px oklch(0.79 0.115 80 / 0);
    }
  }
  .hero-pulse {
    animation: hero-pulse 2.4s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade {
      opacity: 1;
      animation: none;
      transform: none;
    }
    .hero-flicker,
    .hero-pulse {
      animation: none;
    }
  }
</style>
