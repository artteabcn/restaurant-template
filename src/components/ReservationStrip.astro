---
import { useTranslations, localizedPath, type Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative my-16 md:my-24" aria-label={t("reservation.line")}>
  <div
    class="relative overflow-hidden border-y border-[var(--color-line-strong)]"
    style="background:
      linear-gradient(180deg,
        oklch(0.22 0.07 22 / 0.85),
        oklch(0.16 0.05 22 / 0.85)),
      radial-gradient(ellipse at 30% 50%, oklch(0.4 0.13 22 / 0.45), transparent 60%),
      radial-gradient(ellipse at 80% 50%, oklch(0.5 0.1 60 / 0.18), transparent 55%);
    "
  >
    <!-- thin top + bottom gold rules -->
    <div
      class="absolute top-0 left-0 right-0 h-px opacity-50"
      style="background: linear-gradient(to right, transparent, var(--color-gold-deep) 30%, var(--color-gold) 50%, var(--color-gold-deep) 70%, transparent);"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 right-0 h-px opacity-30"
      style="background: linear-gradient(to right, transparent, var(--color-gold-deep) 30%, var(--color-gold) 50%, var(--color-gold-deep) 70%, transparent);"
    >
    </div>

    <div
      class="container-narrow flex flex-col md:flex-row items-center justify-center md:justify-between gap-6 md:gap-12 py-10 md:py-12 text-center md:text-left"
    >
      <div>
        <p class="eyebrow mb-2 text-[var(--color-gold)]">⌖ {t("hero.tonight")}</p>
        <p
          class="display italic text-2xl md:text-3xl text-[var(--color-gold-soft)] leading-snug max-w-xl"
        >
          {t("reservation.line")}
        </p>
      </div>
      <a href={localizedPath(locale, "/booking")} class="btn-primary shrink-0">
        {t("reservation.cta")}
      </a>
    </div>
  </div>
</section>
