---
import { useTranslations, type Locale } from "@/i18n/utils";
import Ornament from "./Ornament.astro";
import { siteConfig } from "@/config/site";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const { mapsLat, mapsLng, whatsapp, socialUrl, socialType } = siteConfig.contact;
const delta = 0.008;
const mapSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${mapsLng - delta},${mapsLat - delta},${mapsLng + delta},${mapsLat + delta}&layer=mapnik&marker=${mapsLat},${mapsLng}`;
const directionsHref = `https://www.google.com/maps/dir/?api=1&destination=${mapsLat},${mapsLng}`;
const whatsappHref = `https://wa.me/${whatsapp.replace(/\D/g, "")}`;
---

<section class="container-narrow py-24">
  <header class="text-center mb-12">
    <Ornament class="mb-6" />
    <h2 class="display italic text-4xl md:text-5xl text-[var(--color-gold-soft)]">
      {t("contact.title")}
    </h2>
  </header>

  <div class="grid md:grid-cols-2 gap-8">
    <div class="panel p-8 flex flex-col justify-between">
      <div class="space-y-8">
        <div>
          <p class="eyebrow mb-2">{t("contact.addressLabel")}</p>
          <p class="text-lg leading-relaxed text-[var(--color-fg)]">
            {t("contact.address")}
          </p>
        </div>

        <div>
          <p class="eyebrow mb-2">{t("contact.whatsappLabel")}</p>
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="text-lg text-[var(--color-gold)] hover:text-[var(--color-gold-soft)]"
          >
            {siteConfig.contact.whatsappDisplay}
          </a>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mt-8">
        <a
          href={directionsHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost">{t("contact.directions")}</a
        >
        {socialType !== "none" && socialUrl && (
          <a
            href={socialUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost">{t("social.follow")}</a>
        )}
      </div>
    </div>

    <div class="panel overflow-hidden min-h-[320px]">
      <iframe
        src={mapSrc}
        title="Map"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full h-full min-h-[320px] grayscale-[0.7] contrast-[1.1] opacity-90"
        style="border:0;"></iframe>
    </div>
  </div>
</section>
