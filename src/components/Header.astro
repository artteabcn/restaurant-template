---
import { useTranslations, localizedPath, type Locale } from "@/i18n/utils";
import LanguageSelector from "./LanguageSelector.tsx";
import { siteConfig } from "@/config/site";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const currentPath = Astro.url.pathname.replace(/^\/(en|fr|th)/, "") || "/";

const links = [
  { href: localizedPath(locale, "/"), label: t("nav.home") },
  { href: localizedPath(locale, "/menu"), label: t("nav.menu") },
  { href: localizedPath(locale, "/booking"), label: t("nav.booking") },
  { href: localizedPath(locale, "/contact"), label: t("nav.contact") },
];
---

<header
  class="sticky top-0 z-40 backdrop-blur-md bg-[oklch(from_var(--color-bg)_l_c_h_/_0.78)] border-b border-[var(--color-line)]"
>
  <div class="container-narrow flex items-center justify-between py-5">
    <a
      href={localizedPath(locale, "/")}
      class="display italic text-2xl text-[var(--color-gold-soft)] tracking-wide"
    >
      {siteConfig.name}
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-fg-muted)] hover:text-[var(--color-gold)] transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <LanguageSelector client:load currentLocale={locale} currentPath={currentPath} />
  </div>

  <!-- mobile nav -->
  <nav class="md:hidden border-t border-[var(--color-line)]">
    <ul class="container-narrow flex justify-between py-3">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-[0.66rem] uppercase tracking-[0.18em] text-[var(--color-fg-muted)]"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
